<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="care_entitlement_view_list" model="ir.ui.view">
        <field name="name">care.package.entitlement.list</field>
        <field name="model">care.package.entitlement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_product_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-muted="state == 'expired'"/>
                <field name="subscription_id"/>
            </list>
        </field>
    </record>

    <record id="care_entitlement_view_form" model="ir.ui.view">
        <field name="name">care.package.entitlement.form</field>
        <field name="model">care.package.entitlement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="package_product_id"/>
                            <field name="subscription_id"/>
                            <field name="sale_order_line_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="سهمیه خدمات">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="included_service_id"/>
                                    <field name="qty_total"/>
                                    <field name="qty_used"/>
                                    <field name="qty_remaining"/>
                                </list>
                            </field>
                        </page>
                        <page string="درخواست‌ها">
                            <field name="request_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="current_step_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="care_entitlement_action" model="ir.actions.act_window">
        <field name="name">سهمیه پکیج‌ها</field>
        <field name="res_model">care.package.entitlement</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
