<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_care" name="Portal My Home: Care Requests" inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_service_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_service_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">درخواست‌های مراقبت</t>
                <t t-set="url" t-value="'/my/care/requests'"/>
                <t t-set="text">ثبت و پیگیری درخواست خدمات مراقبت در منزل</t>
                <t t-set="config_card" t-value="True"/>
                <t t-set="placeholder_count" t-value="'care_request_count'"/>
            </t>
            <t t-if="is_care_provider" t-call="portal.portal_docs_entry">
                <t t-set="title">درخواست‌های من (پذیرنده)</t>
                <t t-set="url" t-value="'/my/care/provider/requests'"/>
                <t t-set="text">درخواست‌های ارجاع‌شده به شما</t>
                <t t-set="config_card" t-value="True"/>
            </t>
            <t t-if="is_care_provider" t-call="portal.portal_docs_entry">
                <t t-set="title">کارهای من</t>
                <t t-set="url" t-value="'/my/care/provider/tasks'"/>
                <t t-set="text">لیست کارهای پذیرفته‌شده با زمان حضور</t>
                <t t-set="config_card" t-value="True"/>
            </t>
        </div>
    </template>

    <template id="portal_my_home_menu_care" name="Portal layout: care menu entries" inherit_id="portal.portal_breadcrumbs" priority="55">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name in ('care_requests', 'care_request_detail', 'care_request_new')" t-attf-class="breadcrumb-item #{'active' if page_name == 'care_requests' else ''}">
                <a t-if="page_name != 'care_requests'" href="/my/care/requests">درخواست‌های مراقبت</a>
                <t t-else="">درخواست‌های مراقبت</t>
            </li>
            <li t-if="page_name == 'care_request_detail' and care_request" class="breadcrumb-item active">
                <t t-esc="care_request.name"/>
            </li>
            <li t-if="page_name == 'care_request_new'" class="breadcrumb-item active">
                درخواست جدید
            </li>
        </xpath>
    </template>

    <template id="portal_care_requests" name="Care Requests">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <div class="container mt-3 o_home_care_portal">
                <div class="hc-page-header d-flex justify-content-between align-items-center">
                    <h2>درخواست‌های مراقبت در منزل</h2>
                    <a href="/my/care/request/new" class="btn btn-light btn-sm">درخواست جدید</a>
                </div>
                <t t-if="not requests">
                    <div class="alert alert-info">هنوز درخواستی ثبت نشده است.</div>
                </t>
                <t t-else="">
                    <div class="table-responsive hc-table">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>شماره</th>
                                    <th>خدمت</th>
                                    <th>پذیرنده</th>
                                    <th>وضعیت</th>
                                    <th>بازه ترجیحی</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="requests" t-as="req">
                                    <td>
                                        <a t-attf-href="/my/care/requests/#{req.id}">
                                            <t t-esc="req.name"/>
                                        </a>
                                    </td>
                                    <td><t t-esc="req.product_id.display_name"/></td>
                                    <td><t t-esc="req.assignee_name or '—'"/></td>
                                    <td><t t-esc="req.portal_status_display or '—'"/></td>
                                    <td><t t-esc="req.preferred_schedule_display or '-'"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <t t-call="portal.pager"/>
                </t>
            </div>
        </t>
    </template>

    <template id="portal_care_request_detail" name="Care Request Detail">
        <t t-call="portal.portal_layout">
            <div class="container mt-3 o_home_care_portal">
                <a href="/my/care/requests" class="btn btn-link mb-2">← بازگشت</a>
                <div class="hc-page-header"><h2><t t-esc="care_request.name"/></h2></div>

                <t t-if="error">
                    <div class="alert alert-danger" t-esc="error"/>
                </t>
                <t t-if="success == 'reject'">
                    <div class="alert alert-success">پذیرنده رد شد؛ درخواست به سایر اعضا ارجاع شد.</div>
                </t>

                <t t-if="care_request.user_id and care_request.state == 'in_progress'">
                    <div class="hc-card mb-3">
                        <div class="hc-card-header">پذیرنده خدمت</div>
                        <div class="hc-card-body d-flex align-items-center gap-3">
                            <t t-if="care_request.assignee_image_url">
                                <img t-att-src="care_request.assignee_image_url" class="rounded-circle" style="width:64px;height:64px;object-fit:cover;border:2px solid #2563eb;"/>
                            </t>
                            <div>
                                <p class="mb-1"><strong><t t-esc="care_request.assignee_name"/></strong></p>
                                <p class="mb-1 text-muted"><t t-esc="care_request.assignee_phone or '—'"/></p>
                                <t t-if="care_request.visit_schedule_display">
                                    <p class="mb-2"><strong>زمان حضور:</strong> <t t-esc="care_request.visit_schedule_display"/></p>
                                </t>
                                <a t-attf-href="/my/care/requests/#{care_request.id}/assignee" class="btn btn-sm hc-btn-primary">مشخصات پذیرنده</a>
                            </div>
                        </div>
                    </div>
                    <t t-if="care_request.can_customer_reject_assignee">
                        <form t-attf-action="/my/care/requests/#{care_request.id}/reject-assignee" method="post" class="d-inline">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-warning" onclick="return confirm('پذیرنده رد شود؟');">این پذیرنده را نمی‌خواهم</button>
                        </form>
                    </t>
                </t>
                <t t-if="care_request.can_customer_cancel_request">
                    <form t-attf-action="/my/care/requests/#{care_request.id}/cancel" method="post" class="d-inline ms-2 mb-3">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <button type="submit" class="btn btn-outline-danger" onclick="return confirm('کل درخواست لغو شود؟');">لغو کل درخواست</button>
                    </form>
                </t>

                <div class="hc-card mb-3">
                    <div class="hc-card-header">جزئیات درخواست</div>
                    <div class="hc-card-body">
                        <p><strong>خدمت:</strong> <t t-esc="care_request.product_id.display_name"/></p>
                        <p><strong>دسته‌بندی:</strong> <t t-esc="care_request.category_id.name"/></p>
                        <p><strong>وضعیت:</strong> <t t-esc="care_request.portal_status_display or '—'"/></p>
                        <p><strong>بازه ترجیحی:</strong> <t t-esc="care_request.preferred_schedule_display or '-'"/></p>
                        <t t-if="care_request.portal_step_instruction">
                            <hr/>
                            <div t-field="care_request.portal_step_instruction"/>
                        </t>
                    </div>
                </div>

                <t t-if="care_request.can_portal_upload">
                    <div class="card mb-3">
                        <div class="card-header">آپلود مدارک</div>
                        <div class="card-body">
                            <form t-attf-action="/my/care/requests/#{care_request.id}/upload" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="mb-3">
                                    <input type="file" name="document" class="form-control" required="required"/>
                                </div>
                                <button type="submit" class="btn btn-secondary">آپلود</button>
                            </form>
                            <t t-if="care_request.attachment_missing">
                                <p class="text-warning mt-2">برای رفتن به مرحله بعد، آپلود مدرک الزامی است.</p>
                            </t>
                        </div>
                    </div>
                </t>

                <t t-if="care_request.document_ids">
                    <div class="card mb-3">
                        <div class="card-header">مدارک آپلودشده</div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center" t-foreach="care_request.document_ids" t-as="doc">
                                <span>
                                    <t t-esc="doc.name"/> — <t t-esc="doc.step_id.name or ''"/>
                                </span>
                                <a t-attf-href="/my/care/requests/#{care_request.id}/documents/#{doc.id}/download"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-download"/> دانلود
                                </a>
                            </li>
                        </ul>
                    </div>
                </t>

                <t t-if="care_invoices">
                    <t t-call="home_care.portal_care_invoices_card">
                        <t t-set="invoice_link_mode" t-value="'portal'"/>
                    </t>
                </t>

                <t t-if="care_request.can_portal_advance">
                    <form t-attf-action="/my/care/requests/#{care_request.id}/advance" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <button type="submit" class="btn btn-primary"
                                t-att-disabled="care_request.attachment_missing and 'disabled' or None">
                            <t t-esc="care_request.advance_step_label or 'مرحله بعد'"/>
                        </button>
                    </form>
                </t>

                <div class="card mt-3">
                    <div class="card-header">تاریخچه مراحل</div>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item" t-foreach="care_request.step_history_ids" t-as="hist">
                            <t t-esc="hist.step_id.name"/> —
                            ورود: <t t-esc="hist.entered_at"/>
                            <t t-if="hist.exited_at"> — خروج: <t t-esc="hist.exited_at"/></t>
                        </li>
                    </ul>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_care_request_new" name="New Care Request">
        <t t-call="portal.portal_layout">
            <div class="container mt-3 o_home_care_portal">
                <div class="hc-page-header"><h2>ثبت درخواست خدمت</h2></div>
                <t t-if="error">
                    <div class="alert alert-danger" t-esc="error"/>
                </t>
                <form action="/my/care/request/create" method="post" class="o_home_care_request_form"
                      t-att-data-partner-name="partner_prefill.get('name', '')"
                      t-att-data-partner-phone="partner_prefill.get('phone', '')"
                      t-att-data-partner-address="partner_prefill.get('address', '')"
                      t-att-data-partner-national-id="partner_prefill.get('national_id', '')">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="mb-3">
                        <label class="form-label">درخواست برای</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="patient_relation" id="patient_relation_self" value="self" checked="checked"/>
                                <label class="form-check-label" for="patient_relation_self">خودم</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="patient_relation" id="patient_relation_other" value="other"/>
                                <label class="form-check-label" for="patient_relation_other">دیگری</label>
                            </div>
                        </div>
                    </div>

                    <div class="hc-card mb-3">
                        <div class="hc-card-header">اطلاعات بیمار</div>
                        <div class="hc-card-body">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label">نام</label>
                                    <input type="text" name="patient_first_name" id="patient_first_name" class="form-control"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">نام خانوادگی</label>
                                    <input type="text" name="patient_last_name" id="patient_last_name" class="form-control"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">کد ملی</label>
                                    <input type="text" name="patient_national_id" id="patient_national_id" class="form-control"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">کد پرونده</label>
                                    <input type="text" name="patient_case_code" class="form-control"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">سن</label>
                                    <input type="number" name="patient_age" class="form-control" min="0"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">جنسیت</label>
                                    <select name="patient_gender" class="form-select">
                                        <option value="">—</option>
                                        <option value="male">مرد</option>
                                        <option value="female">زن</option>
                                        <option value="other">سایر</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">تلفن</label>
                                    <input type="text" name="patient_phone" id="patient_phone" class="form-control"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">موبایل</label>
                                    <input type="text" name="patient_mobile" id="patient_mobile" class="form-control"/>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">آدرس</label>
                                    <textarea name="patient_address" id="patient_address" class="form-control" rows="2"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="hc-card mb-3">
                        <div class="hc-card-header">اطلاعات بیمه</div>
                        <div class="hc-card-body">
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label">بیمه پایه</label>
                                    <select name="insurance_primary_id" class="form-select">
                                        <option value="">— انتخاب کنید —</option>
                                        <t t-foreach="primary_insurances" t-as="ins">
                                            <option t-att-value="ins.id"><t t-esc="ins.name"/></option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">بیمه تکمیلی</label>
                                    <select name="insurance_supplementary_id" class="form-select">
                                        <option value="">— انتخاب کنید —</option>
                                        <t t-foreach="supplementary_insurances" t-as="ins">
                                            <option t-att-value="ins.id"><t t-esc="ins.name"/></option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">نوع درخواست</label>
                        <select name="request_type" class="form-select" id="care_request_type">
                            <option value="package">از پکیج فعال</option>
                            <option value="standalone">خرید جداگانه (سفارش قبلی)</option>
                        </select>
                    </div>

                    <div id="care_package_block" class="mb-3">
                        <label class="form-label">پکیج فعال</label>
                        <select name="entitlement_id" class="form-select" id="care_entitlement_id">
                            <option value="">— انتخاب کنید —</option>
                            <t t-foreach="entitlements" t-as="ent">
                                <option t-att-value="ent.id">
                                    <t t-esc="ent.package_product_id.display_name"/> —
                                    تا <t t-esc="ent.date_end"/>
                                </option>
                            </t>
                        </select>
                        <label class="form-label mt-2">خدمت</label>
                        <select name="product_id" class="form-select" id="care_product_id">
                            <option value="">— ابتدا پکیج را انتخاب کنید —</option>
                        </select>
                    </div>

                    <div id="care_standalone_block" class="mb-3 d-none">
                        <label class="form-label">سفارش / خدمت خریداری‌شده</label>
                        <select name="sale_order_line_id" class="form-select">
                            <option value="">— انتخاب کنید —</option>
                            <t t-foreach="standalone_lines" t-as="line">
                                <option t-att-value="line.id">
                                    <t t-esc="line.order_id.name"/> —
                                    <t t-esc="line.product_id.display_name"/>
                                    (باقیمانده: <t t-esc="line.care_remaining_qty"/>)
                                </option>
                            </t>
                        </select>
                        <p class="text-muted mt-2">
                            برای خرید خدمت جدید، ابتدا از
                            <a href="/shop">فروشگاه</a>
                            محصول خدمت را خریداری کنید.
                        </p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">بازه زمانی ترجیحی</label>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label text-muted small">شروع</label>
                                <input type="datetime-local" name="preferred_datetime_start" class="form-control" required="required"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small">پایان</label>
                                <input type="datetime-local" name="preferred_datetime_end" class="form-control" required="required"/>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">توضیحات</label>
                        <textarea name="description" class="form-control" rows="4"/>
                    </div>

                    <button type="submit" class="btn btn-primary">ثبت درخواست</button>
                </form>
            </div>
        </t>
    </template>

    <template id="portal_care_request_assignee" name="Assignee Profile">
        <t t-call="portal.portal_layout">
            <div class="container mt-3 o_home_care_portal">
                <a t-attf-href="/my/care/requests/#{care_request.id}" class="btn btn-link mb-2">← بازگشت به درخواست</a>
                <div class="hc-card">
                    <div class="hc-card-header">مشخصات پذیرنده خدمت</div>
                    <div class="hc-assignee-profile">
                        <t t-if="care_request.assignee_image_url">
                            <img t-att-src="care_request.assignee_image_url" class="hc-assignee-avatar" alt="پذیرنده"/>
                        </t>
                        <t t-else="">
                            <div class="hc-assignee-avatar-placeholder">
                                <i class="fa fa-user"/>
                            </div>
                        </t>
                        <div class="hc-assignee-name"><t t-esc="care_request.assignee_name"/></div>
                        <p class="text-muted mb-3"><t t-esc="care_request.assignee_team_name or '—'"/></p>
                        <div class="hc-info-row"><span>تلفن</span><strong><t t-esc="care_request.assignee_phone or '—'"/></strong></div>
                        <t t-if="care_request.visit_schedule_display">
                            <div class="hc-info-row"><span>زمان حضور</span><strong><t t-esc="care_request.visit_schedule_display"/></strong></div>
                        </t>
                        <div class="hc-info-row"><span>درخواست</span><strong><t t-esc="care_request.name"/></strong></div>
                        <div class="hc-info-row"><span>خدمت</span><strong><t t-esc="care_request.product_id.display_name"/></strong></div>
                    </div>
                    <div class="hc-card-body border-top">
                        <div class="hc-actions-bar justify-content-center">
                            <t t-if="care_request.can_customer_reject_assignee">
                                <form t-attf-action="/my/care/requests/#{care_request.id}/reject-assignee" method="post" class="d-inline">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn hc-btn-warning" onclick="return confirm('این پذیرنده رد شود؟');">این پذیرنده را نمی‌خواهم</button>
                                </form>
                            </t>
                            <t t-if="care_request.can_customer_cancel_request">
                                <form t-attf-action="/my/care/requests/#{care_request.id}/cancel" method="post" class="d-inline">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn hc-btn-danger-outline" onclick="return confirm('کل درخواست لغو شود؟');">لغو کل درخواست</button>
                                </form>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_provider_requests" name="Provider Requests">
        <t t-call="portal.portal_layout">
            <div class="container mt-3 o_home_care_portal">
                <div class="hc-page-header"><h2>درخواست‌های ارجاع‌شده به من</h2></div>
                <t t-if="not requests"><div class="alert alert-info">درخواستی نیست.</div></t>
                <t t-else="">
                    <div class="hc-table"><table class="table table-hover mb-0">
                        <thead><tr><th>شماره</th><th>مشتری</th><th>خدمت</th><th>زمان حضور</th><th>ارجاع</th><th>وضعیت</th></tr></thead>
                        <tbody>
                            <tr t-foreach="requests" t-as="req">
                                <td><a t-attf-href="/my/care/provider/requests/#{req.id}"><t t-esc="req.name"/></a></td>
                                <td><t t-esc="req.partner_id.name"/></td>
                                <td><t t-esc="req.product_id.display_name"/></td>
                                <td><t t-esc="req.visit_schedule_display or '—'"/></td>
                                <td>
                                    <t t-if="req.user_id == request.env.user">پذیرفته توسط شما</t>
                                    <t t-elif="not req.user_id">در انتظار پذیرش شما</t>
                                    <t t-else="">—</t>
                                </td>
                                <td><t t-esc="req.portal_status_display or '—'"/></td>
                            </tr>
                        </tbody>
                    </table></div>
                    <t t-call="portal.pager"/>
                </t>
            </div>
        </t>
    </template>

    <template id="portal_care_invoices_card" name="Care Invoices Card">
        <div class="hc-card mb-3" id="care-invoices-card">
            <div class="hc-card-header d-flex justify-content-between align-items-center">
                <span>فاکتورهای این درخواست</span>
                <span class="badge bg-secondary"><t t-esc="invoice_count"/></span>
            </div>
            <div class="table-responsive hc-table">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>شماره</th>
                            <th>تاریخ</th>
                            <th>مبلغ</th>
                            <th>وضعیت</th>
                            <th/>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="care_invoices" t-as="inv">
                            <td><t t-esc="inv.name"/></td>
                            <td><t t-esc="inv.invoice_date or '—'"/></td>
                            <td><t t-esc="inv.amount_total"/></td>
                            <td>
                                <t t-if="invoice_link_mode == 'portal'">
                                    <t t-esc="dict(inv._fields['payment_state'].selection).get(inv.payment_state, inv.payment_state)"/>
                                </t>
                                <t t-else="">
                                    <t t-esc="dict(inv._fields['state'].selection).get(inv.state, inv.state)"/>
                                </t>
                            </td>
                            <td>
                                <t t-if="invoice_link_mode == 'portal'">
                                    <a t-att-href="inv.get_portal_url()" class="btn btn-sm hc-btn-primary">مشاهده</a>
                                </t>
                                <t t-else="">
                                    <a t-attf-href="/web#id=#{inv.id}&amp;model=account.move&amp;view_type=form"
                                       class="btn btn-sm hc-btn-primary" target="_blank">مشاهده</a>
                                </t>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </template>

    <template id="portal_provider_request_detail" name="Provider Request Detail">
        <t t-call="portal.portal_layout">
            <div class="container mt-3 o_home_care_portal o_home_care_provider_detail">
                <a href="/my/care/provider/requests" class="btn btn-link mb-2">← بازگشت</a>
                <div class="hc-page-header d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h2 class="mb-0"><t t-esc="care_request.name"/></h2>
                    <div class="hc-header-actions">
                        <t t-if="can_create_invoice">
                            <button type="button" class="btn hc-btn-header o_home_care_open_invoice_wizard"
                                    t-att-data-request-id="care_request.id">
                                <i class="fa fa-plus me-1"/> ایجاد فاکتور
                            </button>
                        </t>
                        <t t-if="invoice_count">
                            <a href="#care-invoices-card" class="btn hc-btn-header">
                                <i class="fa fa-file-text-o me-1"/>
                                فاکتورها (<t t-esc="invoice_count"/>)
                            </a>
                        </t>
                    </div>
                </div>
                <t t-if="error"><div class="alert alert-danger" t-esc="error"/></t>
                <t t-if="success == 'invoice'"><div class="alert alert-success">فاکتور با موفقیت ثبت شد.</div></t>
                <t t-if="success == 'accepted'"><div class="alert alert-success">درخواست را پذیرفتید.</div></t>
                <t t-if="success == 'completed'"><div class="alert alert-success">انجام خدمت ثبت شد.</div></t>
                <t t-if="can_accept">
                    <div class="hc-card mb-3">
                        <div class="hc-card-header">پذیرش درخواست و زمان‌بندی حضور</div>
                        <div class="hc-card-body">
                            <t t-if="care_request.preferred_schedule_display">
                                <p class="text-muted mb-3">
                                    <strong>بازه درخواستی مشتری:</strong>
                                    <t t-esc="care_request.preferred_schedule_display"/>
                                    <span class="d-block small">بازه حضور شما باید داخل این بازه باشد.</span>
                                </p>
                            </t>
                            <form t-attf-action="/my/care/provider/requests/#{care_request.id}/accept" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="row g-2 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">شروع حضور</label>
                                        <input type="datetime-local" name="visit_datetime_start" class="form-control" required="required"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">پایان حضور</label>
                                        <input type="datetime-local" name="visit_datetime_end" class="form-control" required="required"/>
                                    </div>
                                </div>
                                <button type="submit" class="btn hc-btn-primary btn-lg">پذیرش درخواست</button>
                            </form>
                        </div>
                    </div>
                </t>
                <div class="hc-card mb-3">
                    <div class="hc-card-header">جزئیات</div>
                    <div class="hc-card-body">
                        <p><strong>مشتری:</strong> <t t-esc="care_request.partner_id.name"/></p>
                        <p><strong>بیمار:</strong> <t t-esc="care_request.patient_full_name or '—'"/></p>
                        <p><strong>خدمت:</strong> <t t-esc="care_request.product_id.display_name"/></p>
                        <p><strong>وضعیت:</strong> <t t-esc="care_request.portal_status_display or '—'"/></p>
                        <t t-if="care_request.preferred_schedule_display">
                            <p><strong>بازه ترجیحی مشتری:</strong> <t t-esc="care_request.preferred_schedule_display"/></p>
                        </t>
                        <p><strong>آدرس:</strong> <t t-esc="care_request.patient_address or '—'"/></p>
                        <p><strong>تماس:</strong> <t t-esc="care_request.patient_mobile or care_request.patient_phone or '—'"/></p>
                        <t t-if="care_request.visit_schedule_display">
                            <p><strong>زمان حضور:</strong> <t t-esc="care_request.visit_schedule_display"/></p>
                        </t>
                        <p><strong>توضیحات:</strong> <t t-esc="care_request.description or '—'"/></p>
                        <t t-if="care_request.provider_complete_note">
                            <hr/>
                            <p><strong>توضیحات تکمیل:</strong></p>
                            <p class="text-muted mb-0"><t t-esc="care_request.provider_complete_note"/></p>
                        </t>
                        <t t-if="care_request.provider_cancel_note">
                            <hr/>
                            <p><strong>توضیحات لغو:</strong></p>
                            <p class="text-muted mb-0"><t t-esc="care_request.provider_cancel_note"/></p>
                        </t>
                    </div>
                </div>
                <t t-if="care_invoices">
                    <t t-call="home_care.portal_care_invoices_card">
                        <t t-set="invoice_link_mode" t-value="'backend'"/>
                    </t>
                </t>

                <t t-if="can_complete or can_cancel">
                    <div class="hc-card mt-4">
                        <div class="hc-card-header">اقدامات پایانی</div>
                        <div class="hc-card-body">
                            <t t-if="can_complete">
                                <form t-attf-action="/my/care/provider/requests/#{care_request.id}/complete" method="post" class="mb-4">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label class="form-label">توضیحات تکمیل</label>
                                        <textarea name="complete_note" class="form-control" rows="3" placeholder="توضیحات مربوط به انجام خدمت..."/>
                                    </div>
                                    <button type="submit" class="btn hc-btn-success btn-lg">
                                        <t t-esc="care_request.advance_step_label or 'تکمیل / انجام خدمت'"/>
                                    </button>
                                </form>
                            </t>
                            <t t-if="can_cancel">
                                <hr t-if="can_complete"/>
                                <form t-attf-action="/my/care/provider/requests/#{care_request.id}/cancel" method="post"
                                      onsubmit="return confirm('آیا از لغو این درخواست مطمئن هستید؟');">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label class="form-label">توضیحات لغو</label>
                                        <textarea name="cancel_note" class="form-control" rows="3" placeholder="دلیل لغو فرآیند..."/>
                                    </div>
                                    <button type="submit" class="btn btn-outline-danger btn-lg">لغو فرآیند</button>
                                </form>
                            </t>
                        </div>
                    </div>
                </t>

                <div class="modal fade" id="careInvoiceWizardModal" tabindex="-1"
                     aria-labelledby="careInvoiceWizardModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-xl modal-dialog-scrollable">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="careInvoiceWizardModalLabel">فاکتور خدمت اضافه</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"/>
                            </div>
                            <div class="modal-body p-0">
                                <iframe id="careInvoiceWizardFrame" title="فاکتور خدمت اضافه"
                                        style="width:100%;min-height:75vh;border:0;"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_provider_tasks" name="Provider Tasks">
        <t t-call="portal.portal_layout">
            <div class="container mt-3 o_home_care_portal">
                <div class="hc-page-header d-flex justify-content-between align-items-center">
                    <h2>کارهای من</h2>
                    <a href="/my/care/provider/requests" class="btn btn-light btn-sm">درخواست‌های ارجاع‌شده</a>
                </div>
                <t t-if="not tasks"><div class="alert alert-info">کار پذیرفته‌شده‌ای با زمان‌بندی ثبت‌شده نیست.</div></t>
                <t t-else="">
                    <div class="hc-table"><table class="table table-hover mb-0">
                        <thead><tr><th>شماره</th><th>مشتری</th><th>بیمار</th><th>خدمت</th><th>زمان حضور</th><th>مرحله</th></tr></thead>
                        <tbody>
                            <tr t-foreach="tasks" t-as="task">
                                <td><a t-attf-href="/my/care/provider/requests/#{task.id}"><t t-esc="task.name"/></a></td>
                                <td><t t-esc="task.partner_id.name"/></td>
                                <td><t t-esc="task.patient_full_name or '—'"/></td>
                                <td><t t-esc="task.product_id.display_name"/></td>
                                <td><t t-esc="task.visit_schedule_display or '—'"/></td>
                                <td><t t-esc="task.current_step_id.name or '—'"/></td>
                            </tr>
                        </tbody>
                    </table></div>
                    <t t-call="portal.pager"/>
                </t>
            </div>
        </t>
    </template>
</odoo>
