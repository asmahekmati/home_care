<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="care_request_category_view_list" model="ir.ui.view">
        <field name="name">care.request.category.list</field>
        <field name="model">care.request.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="workflow_id"/>
                <field name="default_team_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="care_request_category_view_form" model="ir.ui.view">
        <field name="name">care.request.category.form</field>
        <field name="model">care.request.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="workflow_id"/>
                            <field name="default_team_id"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="care_request_category_action" model="ir.actions.act_window">
        <field name="name">Request Categories</field>
        <field name="res_model">care.request.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
