<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="care_change_assignee_wizard_view_form" model="ir.ui.view">
        <field name="name">care.change.assignee.wizard.form</field>
        <field name="model">care.change.assignee.wizard</field>
        <field name="arch" type="xml">
            <form string="تغییر پذیرنده">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="current_user_id"/>
                    <field name="team_member_ids" invisible="1"/>
                    <field name="new_user_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_confirm" string="تأیید تغییر" type="object" class="btn-primary"/>
                    <button string="انصراف" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
