<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="care_accept_assignment_wizard_view_form" model="ir.ui.view">
        <field name="name">care.accept.assignment.wizard.form</field>
        <field name="model">care.accept.assignment.wizard</field>
        <field name="arch" type="xml">
            <form string="Accept Request">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="visit_datetime_start"/>
                    <field name="visit_datetime_end"/>
                </group>
                <footer>
                    <button name="action_accept" string="Accept" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
