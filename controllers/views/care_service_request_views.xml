<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="care_service_request_view_list" model="ir.ui.view">
        <field name="name">care.service.request.list</field>
        <field name="model">care.service.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="patient_full_name" optional="show"/>
                <field name="request_type"/>
                <field name="product_id"/>
                <field name="category_id"/>
                <field name="current_step_id"/>
                <field name="team_id"/>
                <field name="user_id"/>
                <field name="preferred_schedule_display" optional="show"/>
                <field name="visit_schedule_display" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="care_service_request_view_form" model="ir.ui.view">
        <field name="name">care.service.request.form</field>
        <field name="model">care.service.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_accept_assignment_wizard" string="Accept Request" type="object"
                            class="btn-primary" invisible="not can_current_user_accept"/>
                    <button name="action_proceed_workflow" type="object"
                            class="btn-primary" invisible="state not in ('draft', 'in_progress')">
                        <field name="advance_step_label" readonly="1" nolabel="1" class="d-inline"/>
                    </button>
                    <button name="action_confirm_manual_assignee" string="Confirm Manual Assignment" type="object"
                            class="btn-secondary"
                            groups="home_care.group_care_manager"
                            invisible="state != 'in_progress' or not user_id or assignee_confirmed"/>
                    <button name="action_open_change_assignee_wizard" string="Change Provider" type="object"
                            class="btn-secondary"
                            groups="home_care.group_care_manager"
                            invisible="state != 'in_progress' or not assignee_confirmed"/>
                    <button name="action_provider_complete_service" string="Complete Service" type="object"
                            class="btn-success" invisible="not can_provider_complete_service"/>
                    <button name="action_create_step_invoice" string="Create Invoice" type="object"
                            invisible="not can_step_create_invoice"/>
                    <button name="action_open_provider_invoice_wizard" string="Create Invoice" type="object"
                            invisible="not can_step_create_invoice"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <field name="state" invisible="1"/>
                    <field name="workflow_id" invisible="1"/>
                    <field name="current_step_id" widget="statusbar"
                           domain="[('workflow_id', '=', workflow_id)]"
                           readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_invoices"
                                icon="fa-pencil-square-o">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_sale_order"
                                icon="fa-shopping-cart" invisible="sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo" string="Sales Order"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_entitlement"
                                icon="fa-archive" invisible="entitlement_count == 0">
                            <field name="entitlement_count" widget="statinfo" string="Package Entitlement"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_documents"
                                icon="fa-paperclip">
                            <field name="document_count" widget="statinfo" string="Documents"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_activities"
                                icon="fa-tasks" invisible="activity_count == 0">
                            <field name="activity_count" widget="statinfo" string="Activities"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_related_requests"
                                icon="fa-list-alt" invisible="related_request_count == 0">
                            <field name="related_request_count" widget="statinfo" string="Related Requests"/>
                        </button>
                    </div>
                    <field name="can_current_user_accept" invisible="1"/>
                    <field name="can_provider_complete_service" invisible="1"/>
                    <field name="can_step_create_invoice" invisible="1"/>
                    <field name="assignee_confirmed" invisible="1"/>
                    <field name="invoice_count" invisible="1"/>
                    <field name="related_request_count" invisible="1"/>
                    <field name="sale_order_count" invisible="1"/>
                    <field name="entitlement_count" invisible="1"/>
                    <field name="document_count" invisible="1"/>
                    <field name="activity_count" invisible="1"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group string="Service Request">
                        <group>
                            <field name="partner_id"/>
                            <field name="request_type"/>
                            <field name="entitlement_domain_ids" invisible="1"/>
                            <field name="sale_order_line_domain_ids" invisible="1"/>
                            <field name="product_domain_ids" invisible="1"/>
                            <field name="entitlement_id"
                                   invisible="request_type != 'package'"
                                   options="{'no_create': True}"
                                   context="{'care_service_request': True}"/>
                            <field name="sale_order_line_id"
                                   invisible="request_type != 'standalone'"
                                   options="{'no_create': True}"
                                   context="{'care_service_request_line': True}"/>
                            <field name="product_id" options="{'no_create': True}"/>
                            <field name="category_id" readonly="1"/>
                            <field name="patient_relation"/>
                        </group>
                        <group>
                            <field name="workflow_id" readonly="1"/>
                            <field name="current_step_id" readonly="1"/>
                            <field name="team_id"/>
                            <field name="user_id" readonly="assignee_confirmed"/>
                            <field name="assignee_confirmed" readonly="1"/>
                            <field name="pending_assignment_count" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Scheduling">
                        <group>
                            <field name="preferred_datetime_start"/>
                            <field name="preferred_datetime_end"/>
                            <field name="preferred_schedule_display" readonly="1"/>
                        </group>
                        <group>
                            <field name="visit_datetime_start" readonly="1"/>
                            <field name="visit_datetime_end" readonly="1"/>
                            <field name="visit_schedule_display" readonly="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Request description..."/>
                    <notebook>
                        <page string="Identity Information" name="patient_identity">
                            <group>
                                <group string="Patient Details">
                                    <field name="patient_first_name"/>
                                    <field name="patient_last_name"/>
                                    <field name="patient_full_name" readonly="1"/>
                                    <field name="patient_national_id"/>
                                    <field name="patient_case_code"/>
                                    <field name="patient_age"/>
                                    <field name="patient_gender"/>
                                </group>
                                <group string="Contact &amp; Address">
                                    <field name="patient_phone"/>
                                    <field name="patient_mobile"/>				
                                    <field name="patient_address"/>
                                </group>
                            </group>
                        </page>
                        <page string="Insurance Information" name="patient_insurance">
                            <group>
                                <group string="Primary Insurance">
                                    <field name="insurance_primary_id" options="{'no_create': True}"/>
                                </group>
                                <group string="Supplementary Insurance">
                                    <field name="insurance_supplementary_id" options="{'no_create': True}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Provider Notes" name="provider_notes"
                              invisible="not provider_complete_note and not provider_cancel_note">
                            <group>
                                <field name="provider_complete_note" readonly="1"/>
                                <field name="provider_cancel_note" readonly="1"/>
                            </group>
                        </page>
                        <page string="Activities" name="care_activities">
                            <field name="activity_ids" widget="list_activity"
                                   context="{'default_res_model': 'care.service.request', 'default_res_id': id}"/>
                        </page>
                        <page string="Team Assignment" name="team_assignment"
                              invisible="not assignment_offer_ids">
                            <field name="assignment_offer_ids" readonly="1">
                                <list decoration-success="state == 'accepted'"
                                      decoration-muted="state == 'cancelled'">
                                    <field name="step_id"/>
                                    <field name="user_id"/>
                                    <field name="team_id"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'pending'"
                                           decoration-success="state == 'accepted'"/>
                                    <field name="accepted_at"/>
                                    <field name="sms_sent"/>
                                </list>
                            </field>
                        </page>
                        <page string="Documents" name="documents">
                            <field name="document_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="step_id"/>
                                    <field name="uploaded_by_id"/>
                                    <field name="create_date"/>
                                    <field name="attachment_id" column_invisible="True"/>
                                    <button name="action_download" type="object"
                                            string="Download" icon="fa-download" title="Download"/>
                                </list>
                            </field>
                        </page>
                        <page string="Step History" name="step_history">
                            <field name="step_history_ids">
                                <list>
                                    <field name="step_id"/>
                                    <field name="entered_at"/>
                                    <field name="exited_at"/>
                                    <field name="user_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Invoices" name="invoices">
                            <field name="invoice_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="invoice_date"/>
                                    <field name="amount_total"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="care_service_request_view_kanban" model="ir.ui.view">
        <field name="name">care.service.request.kanban</field>
        <field name="model">care.service.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="current_step_id" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="patient_full_name"/>
                <field name="product_id"/>
                <field name="current_step_id"/>
                <field name="team_id"/>
                <field name="user_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold"/>
                        <div><field name="partner_id"/></div>
                        <div t-if="record.patient_full_name.value">
                            Patient: <field name="patient_full_name"/>
                        </div>
                        <div><field name="product_id"/></div>
                        <div class="text-muted"><field name="team_id"/> — <field name="user_id"/></div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="care_service_request_view_calendar" model="ir.ui.view">
        <field name="name">care.service.request.calendar</field>
        <field name="model">care.service.request</field>
        <field name="arch" type="xml">
            <calendar string="Visit Schedule" date_start="visit_datetime_start"
                      date_stop="visit_datetime_end" color="user_id" mode="week">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="patient_full_name"/>
                <field name="product_id"/>
            </calendar>
        </field>
    </record>

    <record id="care_service_request_action" model="ir.actions.act_window">
        <field name="name">Service Requests</field>
        <field name="res_model">care.service.request</field>
        <field name="view_mode">list,form,kanban,graph,pivot</field>
        <field name="group_ids" eval="[(4, ref('home_care.group_care_user'))]"/>
    </record>
</odoo>
