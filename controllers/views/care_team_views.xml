<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="care_team_view_list" model="ir.ui.view">
        <field name="name">care.team.list</field>
        <field name="model">care.team</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="leader_id"/>
                <field name="member_ids" widget="many2many_tags"/>
                <field name="request_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="care_team_view_form" model="ir.ui.view">
        <field name="name">care.team.form</field>
        <field name="model">care.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_requests" type="object" class="oe_stat_button" icon="fa-tasks">
                            <field name="request_count" widget="statinfo" string="Requests"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="leader_id"/>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Team Members">
                        <field name="member_ids" widget="many2many_tags"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="care_team_action" model="ir.actions.act_window">
        <field name="name">Care Teams</field>
        <field name="res_model">care.team</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
