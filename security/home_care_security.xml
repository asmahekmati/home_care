<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="res.groups.privilege" id="res_groups_privilege_home_care">
        <field name="name">مراقبت در منزل</field>
        <field name="placeholder">کاربر</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>

    <record id="group_care_user" model="res.groups">
        <field name="name">کاربر</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_home_care"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_care_provider" model="res.groups">
        <field name="name">پذیرنده</field>
        <field name="sequence">15</field>
        <field name="privilege_id" ref="res_groups_privilege_home_care"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_care_manager" model="res.groups">
        <field name="name">مدیر</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_home_care"/>
        <field name="implied_ids" eval="[(4, ref('home_care.group_care_user')), (4, ref('home_care.group_care_provider'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="care_request_rule_portal" model="ir.rule">
        <field name="name">Care Request: portal own</field>
        <field name="model_id" ref="model_care_service_request"/>
        <field name="domain_force">[('partner_id', 'child_of', user.partner_id.commercial_partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="care_request_rule_portal_provider" model="ir.rule">
        <field name="name">Care Request: portal provider offer</field>
        <field name="model_id" ref="model_care_service_request"/>
        <field name="domain_force">[
            '|',
            ('user_id', '=', user.id),
            '&amp;',
            ('user_id', '=', False),
            '&amp;',
            ('assignment_offer_ids.user_id', '=', user.id),
            ('assignment_offer_ids.state', '=', 'pending'),
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="care_assignment_offer_rule_portal" model="ir.rule">
        <field name="name">Care Assignment Offer: portal own</field>
        <field name="model_id" ref="model_care_request_assignment_offer"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="care_entitlement_rule_portal" model="ir.rule">
        <field name="name">Care Entitlement: portal own</field>
        <field name="model_id" ref="model_care_package_entitlement"/>
        <field name="domain_force">[('partner_id', 'child_of', user.partner_id.commercial_partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="care_document_rule_portal" model="ir.rule">
        <field name="name">Care Document: portal own request</field>
        <field name="model_id" ref="model_care_request_document"/>
        <field name="domain_force">[('request_id.partner_id', 'child_of', user.partner_id.commercial_partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="care_request_rule_user" model="ir.rule">
        <field name="name">Care Request: staff all</field>
        <field name="model_id" ref="model_care_service_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('home_care.group_care_user'))]"/>
    </record>

    <record id="care_request_rule_manager" model="ir.rule">
        <field name="name">Care Request: manager all</field>
        <field name="model_id" ref="model_care_service_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('home_care.group_care_manager'))]"/>
    </record>

    <record id="care_request_rule_provider" model="ir.rule">
        <field name="name">Care Request: provider assigned or pending</field>
        <field name="model_id" ref="model_care_service_request"/>
        <field name="domain_force">[
            '|',
            ('user_id', '=', user.id),
            '&amp;',
            ('user_id', '=', False),
            '&amp;',
            ('assignment_offer_ids.user_id', '=', user.id),
            ('assignment_offer_ids.state', '=', 'pending'),
        ]</field>
        <field name="groups" eval="[(4, ref('home_care.group_care_provider'))]"/>
    </record>

    <record id="care_document_rule_provider" model="ir.rule">
        <field name="name">Care Document: provider own request</field>
        <field name="model_id" ref="model_care_request_document"/>
        <field name="domain_force">[
            '|',
            ('request_id.user_id', '=', user.id),
            '&amp;',
            ('request_id.user_id', '=', False),
            '&amp;',
            ('request_id.assignment_offer_ids.user_id', '=', user.id),
            ('request_id.assignment_offer_ids.state', '=', 'pending'),
        ]</field>
        <field name="groups" eval="[(4, ref('home_care.group_care_provider'))]"/>
    </record>
</odoo>
